# ignore gzip files
*.gz

# sometimes configs like to generate noisy node files, begone with them
node_modules/
*/node_modules/

# ignore any build, bin, or obj from plugin generation
build/
*/build/
bin/
*/bin/
obj/
*/obj/

# also ignore any possible .idea or .vscode directories in case they accidentally get added
.idea/
.vscode/

# Make especially sure no .env files make it in
.env
*.env
*.env.*

# ignore lazy lock file
*/lazy-lock.json
*.lock.json

# make sure we don't capture undo trees
*.undo

*error.log*
